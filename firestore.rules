rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in ['shimirwabruno1@gmail.com', 'umwemubi@gmail.com'];
    }

    match /rooms/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /services/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /academy/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /classes/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /siteSettings/{id} { allow read: if true; allow write: if isAdmin(); }

    match /bookings/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /messages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}