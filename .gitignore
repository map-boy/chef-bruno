android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# ── Capacitor ─────────────────────────────────────────────
.capacitor/

# ── iOS (if added later) ──────────────────────────────────
ios/App/App/public/
ios/App/Pods/
ios/.xcode.env.local

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
