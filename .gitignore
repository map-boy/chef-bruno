# ── Dependencies ──────────────────────────────────────────
node_modules/
functions/node_modules/

# ── Build outputs ─────────────────────────────────────────
dist/
dist-app/
build/
coverage/

# ── Environment & secrets ─────────────────────────────────
.env
.env.*
!.env.example
firebase-applet-config.json

# ── Android build artifacts ───────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/capacitor-cordova-android-plugins/

# ── Android generated assets (rebuilt by cap sync) ────────
